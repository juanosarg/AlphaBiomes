	<ThingDef ParentName="PlantBase">
		<defName>AB_GiantTrumpetglory</defName>
		<label>giant trumpetglories</label>
		<description>A cluster of large, trumpet-shaped blossoms reminiscent of morning glories. These giant flowers were genetically modified by a long-forgotten genetics company. These seem to be blooming almost continuously. Their stalks are not strong enough to be used as a wood substitute, but they are incredibly pretty.\n\nPlant details: Giant trumpetglory is a wild plant that cannot be cultivated. Very beautiful.</description>
		<graphicData>
			<texPath>Things/Plants/AB_GiantDryFlower</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.18, 0.3, 0.15)</volume>
			</shadowData>
		</graphicData>
		<selectable>true</selectable>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
		<minifiedDef>MinifiedTree</minifiedDef>
		<rotatable>false</rotatable>
		<statBases>
			<Beauty>5</Beauty>
			<BeautyOutdoors>5</BeautyOutdoors>
			<MaxHitPoints>200</MaxHitPoints>
			<Flammability>2</Flammability>
			<Nutrition>2.0</Nutrition>
			<Mass>150</Mass>
		</statBases>
		<plant>
			<leaflessGraphicPath>Things/Plants/AB_GiantDryFlower_Leafless</leaflessGraphicPath>
			<growDays>14</growDays>
			<wildClusterRadius>10</wildClusterRadius>
			<wildClusterWeight>11</wildClusterWeight>
			<visualSizeRange>2.8~3.8</visualSizeRange>
			<sowTags Inherit="false">				
			</sowTags>
			<sowResearchPrerequisites Inherit="false">      
			</sowResearchPrerequisites>
			<lifespanDaysPerGrowDays>9</lifespanDaysPerGrowDays>
			<fertilitySensitivity>0.5</fertilitySensitivity>
			<treeLoversCareIfChopped>true</treeLoversCareIfChopped>
			<burnedThingDef IsNull="True"/>
			<choppedThingDef IsNull="True"/>
			<smashedThingDef IsNull="True"/>
			<treeCategory>Full</treeCategory>
			<topWindExposure>0.25</topWindExposure>
			<wildOrder>3</wildOrder>
			<interferesWithRoof>true</interferesWithRoof>
		</plant>
		<ingestible>
			<foodType>Tree</foodType>
			<preferability>RawBad</preferability>
		</ingestible>
	</ThingDef>
	<ThingDef ParentName="TreeBase">
		<defName>AB_GiantPaleRose</defName>
		<label>giant pale roses</label>
		<description>Giant flowers genetically modified by a long-forgotten genetics company using the genome of a rose. These seem to be blooming almost continuously. Their stalks are very strong and durable, so they can be cut and used as a wood substitute.\n\nPlant details: Giant pale rose is a wild plant that cannot be cultivated, and it needs minimum terrain fertility of 0.7. Can be harvested for wood.</description>
		<descriptionHyperlinks>
			<ThingDef>WoodLog</ThingDef>
		</descriptionHyperlinks>
		<graphicData>
			<texPath>Things/Plants/AB_GiantDryRose</texPath>
