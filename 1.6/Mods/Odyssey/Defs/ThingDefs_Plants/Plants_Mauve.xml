<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="PlantBase">
		<defName>AB_BloodGrass</defName>
		<label>blood grass</label>
		<description>Looks dangerous.</description>
		<statBases>
			<MaxHitPoints>85</MaxHitPoints>
			<Flammability>1.3</Flammability>
			<Nutrition>0.30</Nutrition>
		</statBases>
		<graphicData>
			<texPath>Things/Plants/AB_RedGrass</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<hideAtSnowOrSandDepth>0.5</hideAtSnowOrSandDepth>
		<ingestible/>
		<selectable>false</selectable>
		<plant>
			
			<growDays>2.5</growDays>
			<harvestWork>40</harvestWork>
			<maxMeshCount>9</maxMeshCount>
			<visualSizeRange>0.4~0.6</visualSizeRange>
			<topWindExposure>0.4</topWindExposure>
			<wildOrder>1</wildOrder>
		</plant>
	</ThingDef>
	  <ThingDef ParentName="BushBase" >
    <defName>AB_Plant_MauveBush</defName>
    <label>mauve bush</label>
    <description>A short mauve shrub. Does not typically talk without alcohol being involved.</description>
    <graphicData>
      <texPath>Things/Plants/AB_MauveBush</texPath>
      <drawSize>1.15</drawSize>
      <shadowData>
        <volume>(0.55, 0.2, 0.2)</volume>
      </shadowData>
    </graphicData>
    <uiIconScale>0.85</uiIconScale>
    <plant>
      <growDays>3</growDays>
      <leaflessGraphicPath>Things/Plant/Bush_Leafless</leaflessGraphicPath>
      <leaflessSnowOverlayGraphicPath>Things/Plant/Bush_LeaflessSnowy</leaflessSnowOverlayGraphicPath>
	  <wildOrder>1</wildOrder>
    </plant>
  </ThingDef>

  <ThingDef ParentName="PlantBase" >
    <defName>AB_Plant_MauveBrambles</defName>
    <label>mauve brambles</label>
    <description>Tangled, thorny, woody shoots covered with mauve leaves. Brambles grow in clusters, and slow down anyone moving over them.</description>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <Nutrition>0.50</Nutrition>
    </statBases>
    <pathCost>14</pathCost>
    <graphicData>
      <texPath>Things/Plants/AB_MauveBrambles</texPath>
      <drawSize>1.7</drawSize>
      <graphicClass>Graphic_Random</graphicClass>
    </graphicData>
    <ingestible />
    <plant>
      <fertilitySensitivity>0.7</fertilitySensitivity>
      <growDays>3</growDays>
      <harvestWork>60</harvestWork>
      <maxMeshCount>4</maxMeshCount>
      <leaflessGraphicPath>Things/Plant/Brambles_Leafless</leaflessGraphicPath>
    
      <leaflessSnowOverlayGraphicPath>Things/Plant/Brambles_LeaflessSnowy</leaflessSnowOverlayGraphicPath>
      <visualSizeRange>0.7~0.85</visualSizeRange>
      <topWindExposure>0.15</topWindExposure>
      <wildClusterRadius>4</wildClusterRadius>
      <wildClusterWeight>200</wildClusterWeight>
      <wildOrder>1</wildOrder>
      <wildEqualLocalDistribution>false</wildEqualLocalDistribution>
      <pollution>Any</pollution>
    </plant>
  </ThingDef>
	<ThingDef ParentName="TreeBase">
		<defName>AB_Plant_MauvebloomTree</defName>
		<label>weeping mauvebloom</label>
		<description>A graceful tree with dense mauve foliage that constantly exudes thick, syrupy droplets.\n\nBased on artwork by Splix04, https://splix04.itch.io</description>
		<graphicData>
			<texPath>Things/Plants/AB_PurpleTree</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.2, 0.3, 0.13)</volume>
				<offset>(0,0,-0.44)</offset>
			</shadowData>
		</graphicData>
		<statBases>
			<Beauty>0</Beauty>
			<BeautyOutdoors>1</BeautyOutdoors>
		</statBases>
		<plant>
			<growDays>30</growDays>		
			 <harvestWork>1400</harvestWork>
			<harvestYield>46</harvestYield>
			<wildClusterWeight>35</wildClusterWeight>
			<visualSizeRange>1.8~2.8</visualSizeRange>
			<wildOrder>1</wildOrder>
		</plant>
	</ThingDef>
</Defs>