<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="PlantBase">
		<defName>AB_GauGrass</defName>
		<label>gau grass</label>
		<description>Orange tinted grass that moves silently in the wind.</description>
		<statBases>
			<MaxHitPoints>85</MaxHitPoints>
			<Flammability>1.3</Flammability>
			<Nutrition>0.30</Nutrition>
		</statBases>
		<graphicData>
			<texPath>Things/Plants/AB_GauGrass</texPath>
			<graphicClass>Graphic_Random</graphicClass>
		</graphicData>
		<hideAtSnowOrSandDepth>0.5</hideAtSnowOrSandDepth>
		<ingestible/>
		<selectable>false</selectable>
		<plant>
			
			<growDays>2.5</growDays>
			<harvestWork>40</harvestWork>
			<maxMeshCount>9</maxMeshCount>
			<visualSizeRange>0.4~0.6</visualSizeRange>
			<topWindExposure>0.4</topWindExposure>
			<wildOrder>1</wildOrder>
		</plant>
	</ThingDef>
	<ThingDef ParentName="PlantBase" MayRequire="Ludeon.RimWorld.Ideology">
		<defName>AB_GauMoss</defName>
		<label>lesser gauranlen moss</label>
		<description>Symbiotic moss that grows in Gauranlen groves.</description>
		<statBases>
			<MaxHitPoints>85</MaxHitPoints>
			<Flammability>1.3</Flammability>
			<Nutrition>0.1</Nutrition>
		</statBases>
		<graphicData>
			 <texPath>Things/Plant/GauranlenMoss</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <drawSize>(0.75, 0.75)</drawSize>
		</graphicData>
		<hideAtSnowOrSandDepth>0.5</hideAtSnowOrSandDepth>
		<ingestible/>
		<selectable>false</selectable>
		<plant>
			 <maxMeshCount>4</maxMeshCount>
			<growDays>5</growDays>
			<harvestWork>40</harvestWork>
			
			  <visualSizeRange>0.5~0.7</visualSizeRange>
			<topWindExposure>0.4</topWindExposure>
			<wildOrder>1</wildOrder>
		</plant>
	</ThingDef>
	  <ThingDef ParentName="BushBase" >
    <defName>AB_Plant_GauBush</defName>
    <label>gau bush</label>
    <description>A short orange-tinted shrub. Does not typically talk without alcohol being involved.</description>
    <graphicData>
      <texPath>Things/Plants/AB_GauBush</texPath>
      <drawSize>1.15</drawSize>
      <shadowData>
        <volume>(0.55, 0.2, 0.2)</volume>
      </shadowData>
    </graphicData>
    <uiIconScale>0.85</uiIconScale>
    <plant>
      <growDays>3</growDays>
      <leaflessGraphicPath>Things/Plant/Bush_Leafless</leaflessGraphicPath>
      <leaflessSnowOverlayGraphicPath>Things/Plant/Bush_LeaflessSnowy</leaflessSnowOverlayGraphicPath>
	  <wildOrder>1</wildOrder>
    </plant>
  </ThingDef>

  <ThingDef ParentName="PlantBase" >
    <defName>AB_Plant_GauBrambles</defName>
    <label>gau brambles</label>
    <description>Tangled, thorny, woody shoots covered with orange leaves. Brambles grow in clusters, and slow down anyone moving over them.</description>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <Nutrition>0.50</Nutrition>
    </statBases>
    <pathCost>14</pathCost>
    <graphicData>
      <texPath>Things/Plants/AB_GauBrambles</texPath>
      <drawSize>1.7</drawSize>
      <graphicClass>Graphic_Random</graphicClass>
    </graphicData>
    <ingestible />
    <plant>
      <fertilitySensitivity>0.7</fertilitySensitivity>
      <growDays>3</growDays>
      <harvestWork>60</harvestWork>
      <maxMeshCount>4</maxMeshCount>
      <leaflessGraphicPath>Things/Plant/Brambles_Leafless</leaflessGraphicPath>
    
      <leaflessSnowOverlayGraphicPath>Things/Plant/Brambles_LeaflessSnowy</leaflessSnowOverlayGraphicPath>
      <visualSizeRange>0.7~0.85</visualSizeRange>
      <topWindExposure>0.15</topWindExposure>
      <wildClusterRadius>4</wildClusterRadius>
      <wildClusterWeight>200</wildClusterWeight>
      <wildOrder>1</wildOrder>
      <wildEqualLocalDistribution>false</wildEqualLocalDistribution>
      <pollution>Any</pollution>
    </plant>
  </ThingDef>
	<ThingDef ParentName="TreeBase">
		<defName>AB_Plant_GiantGauTree</defName>
		<label>giant gauranlen tree</label>
		<description>An enormous relative of the Gauranlen tree. Though it shares the same distinctive appearance and faint psychic resonance, it no longer produces dryads. Some believe these giants are ancient Gauranlens whose inner queens have long since fallen dormant, while others claim they are the timeless homes of powerful nature spirits.</description>
		<graphicData>
			<texPath>Things/Plants/AB_GiantGauTree</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<shadowData>
				<volume>(0.2, 0.3, 0.13)</volume>
				<offset>(0,0,-0.44)</offset>
			</shadowData>
		</graphicData>
		<statBases>
			<Beauty>2</Beauty>
			<BeautyOutdoors>10</BeautyOutdoors>
		</statBases>
		<plant>
			<growDays>60</growDays>		
			 <harvestWork>1400</harvestWork>
			<harvestYield>46</harvestYield>
			<wildClusterWeight>35</wildClusterWeight>
			<visualSizeRange>2.8~3.8</visualSizeRange>
			<wildOrder>1</wildOrder>
		</plant>
	</ThingDef>
</Defs>