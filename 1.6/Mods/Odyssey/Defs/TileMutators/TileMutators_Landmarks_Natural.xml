		<workerClass>AlphaBiomes.TileMutatorWorker_MauvebloomFields</workerClass>
		<biomeWhitelist>
			<li>TemperateForest</li>
			<li>TemperateSwamp</li>
		</biomeWhitelist>
	</TileMutatorDef>
	<TileMutatorDef>
		<defName>AB_ReddishWaters</defName>
		<label>reddish water</label>
		<description>The waters here are stained a deep crimson by dense blooms of red algae and pigmented microorganisms.</description>
		<workerClass>AlphaBiomes.TileMutatorWorker_ReddishWaters</workerClass>
		<biomeWhitelist>
			<li>TemperateForest</li>
			<li>TemperateSwamp</li>
		</biomeWhitelist>
	</TileMutatorDef>
	<TileMutatorDef>
		<defName>AB_ReddishRains</defName>
		<label>reddish rains</label>
		<description>Periodic blooms of airborne red algae cause rain to fall in unsettling shades of pink and crimson, as though the skies themselves were bleeding.</description>
		<categories>
			<li>Weather</li>
		</categories>
		<workerClass>TileMutatorWorker_IncreaseWeatherFrequency</workerClass>
		<weathersToAffect>
			<li>AB_ReddishRain</li>
		</weathersToAffect>
