						<forcedPawnKindDefChance>1</forcedPawnKindDefChance>
					</li>
				</forcedPawnKindDefs>
			</li>
		</modExtensions>
	</TileMutatorDef>
	<TileMutatorDef>
		<defName>AB_DryMeadows</defName>
		<label>dry meadows soils</label>
