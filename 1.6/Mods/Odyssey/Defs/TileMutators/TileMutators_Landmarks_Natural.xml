						<plantDef>AB_EyeGrass</plantDef>
						<commonality>1</commonality>
					</li>
				</plantDefsWithCommonality>
			</li>
		</modExtensions>
	</TileMutatorDef>
	<TileMutatorDef>
		<defName>AB_RedFog</defName>
		<label>red fog</label>
		<description>A sickening red fog that reduces the accuracy of ranged weapons permeates this region.</description>
		<categories>
			<li>Weather</li>
		</categories>
		<workerClass>TileMutatorWorker_IncreaseWeatherFrequency</workerClass>
		<weathersToAffect>
			<li>AB_RedFog</li>
		</weathersToAffect>
		<weatherFrequencyOffset>15</weatherFrequencyOffset>
	</TileMutatorDef>
	<TileMutatorDef MayRequire="sarg.alphaanimals">
		<defName>AB_MobileCacti</defName>
		<label>mobile cacti</label>
		<description>Some of the ocular cacti in this region are mobile.</description>
		<workerClass>VEF.Maps.TileMutatorWorker_ExtraAnimal</workerClass>
		<biomeWhitelist>
			<li>Desert</li>
			<li>ExtremeDesert</li>
		</biomeWhitelist>
		<modExtensions>
			<li Class="VEF.Maps.TileMutatorExtension">
				<forcedPawnKindDefs>
					<li MayRequire="sarg.alphaanimals">
